#!/usr/bin/env node
/* src/cli/pkg/bin/seam */

const { platform, arch } = process;
const { spawnSync } = require("child_process");
const { existsSync } = require("fs");
const { join } = require("path");

const PLATFORM_PACKAGES = {
  "darwin-arm64": "@canmi/seam-cli-darwin-arm64",
  "darwin-x64": "@canmi/seam-cli-darwin-x64",
  "linux-x64": "@canmi/seam-cli-linux-x64",
  "linux-arm64": "@canmi/seam-cli-linux-arm64",
};

function findBinary() {
  const pkg = PLATFORM_PACKAGES[`${platform}-${arch}`];
  if (!pkg) return null;
  try {
    const pkgDir = join(require.resolve(`${pkg}/package.json`), "..");
    const bin = join(pkgDir, "bin", "seam");
    if (existsSync(bin)) return bin;
  } catch {
    // Platform package not installed, fall through to PATH
  }
  return null;
}

const binary = findBinary() || "seam";
const result = spawnSync(binary, process.argv.slice(2), {
  stdio: "inherit",
  shell: false,
});

if (result.error) {
  if (result.error.code === "ENOENT") {
    console.error(
      `seam: binary not found for ${platform}-${arch}.\n` +
        "Install via cargo: cargo install seam-cli",
    );
  } else {
    console.error("Failed to execute seam CLI:", result.error);
  }
  process.exit(1);
}

process.exitCode = result.status;
